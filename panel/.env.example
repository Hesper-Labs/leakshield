# LeakShield admin panel environment variables.
# Copy this file to `.env.local` and fill in real values for local development.

# Public base URL of the Go gateway. Browser-side fetches use this directly,
# server-side fetches resolve through the panel's runtime environment.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Server-side gateway URL used by Auth.js Credentials provider, the SSE proxy
# route, and any RSC fetches. In Docker compose this is the in-network DNS
# name; override at deploy time. Falls back to NEXT_PUBLIC_API_URL if unset.
GATEWAY_INTERNAL_URL=http://gateway:8080

# Auth.js v5 secret. MUST be at least 32 random bytes in production.
# Generate with: `openssl rand -base64 32`.
AUTH_SECRET=replace-me-with-a-real-secret-at-least-32-bytes

# Optional. If set, Auth.js will trust this URL for redirects.
# AUTH_URL=http://localhost:3000

# Default locale for next-intl. English first, Turkish second.
NEXT_PUBLIC_DEFAULT_LOCALE=en
